{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pip install --break-system-packages -r api/requirements.txt",
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{web/**,tests/**,docs/**,.github/**,node_modules/**,dist/**,.venv/**,__pycache__/**}"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }]
}
