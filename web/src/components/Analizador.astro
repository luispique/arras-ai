---
import { EJEMPLOS } from "../examples";
---

<section class="mx-auto max-w-2xl">
  <!-- Product card: light surface on the warm canvas, hairline border, one soft shadow. -->
  <div class="no-print rounded-xl border border-ink-muted/40 bg-surface p-5 shadow-subtle sm:p-7">
    <!-- Pill tab toggle -->
    <div class="mb-5 inline-flex rounded-pill bg-canvas p-1" id="tabs">
      <button
        data-modo="texto"
        class="tab rounded-pill bg-ink px-4 py-1.5 text-[15px] font-medium text-surface"
        >Pegar texto</button
      >
      <button
        data-modo="pdf"
        class="tab rounded-pill px-4 py-1.5 text-[15px] font-medium text-ink-mid"
        >Subir PDF</button
      >
    </div>

    <div id="panel-texto">
      <textarea
        id="texto"
        rows="9"
        maxlength="30000"
        class="w-full resize-y rounded-md border border-ink-muted/50 bg-canvas/40 p-3.5 text-[14px] leading-relaxed text-ink placeholder:text-ink-muted focus:border-ink focus:outline-none"
        placeholder="Pega aquí el texto del contrato de arras…"></textarea>
      <div class="mt-3 flex flex-wrap items-center gap-2 text-sm">
        <span class="text-ink-mid">Prueba con un ejemplo:</span>
        {
          EJEMPLOS.map((e) => (
            <button
              class="ejemplo rounded-pill border border-ink-muted/50 px-3 py-1 text-[13px] text-ink-mid transition-colors hover:border-ink hover:text-ink"
              data-id={e.id}
            >
              {e.etiqueta}
            </button>
          ))
        }
      </div>
    </div>

    <div id="panel-pdf" class="hidden">
      <label
        class="flex cursor-pointer flex-col items-center justify-center rounded-md border border-dashed border-ink-muted/60 bg-canvas/40 px-4 py-10 text-center transition-colors hover:border-ink"
      >
        <input id="pdf" type="file" accept="application/pdf" class="sr-only" />
        <span class="text-[15px] font-medium text-ink">Selecciona un PDF</span>
        <span id="pdf-nombre" class="mt-1 text-sm text-ink-mid">Máximo 5 MB · 15 páginas</span>
      </label>
    </div>

    <button
      id="analizar"
      class="mt-5 inline-flex items-center gap-2 rounded-pill bg-ink px-6 py-3 text-[15px] font-medium text-surface transition-opacity hover:opacity-90 disabled:opacity-40"
    >
      <span id="analizar-label">Analizar contrato</span>
      <span
        id="spinner"
        class="hidden h-4 w-4 animate-spin rounded-full border-2 border-surface/40 border-t-surface"
      ></span>
    </button>

    <p
      id="error"
      class="mt-4 hidden rounded-md border border-danger/30 bg-danger/5 p-3 text-sm text-danger"
    >
    </p>

    <p class="mt-4 flex items-start gap-1.5 text-xs leading-relaxed text-ink-mid">
      <span aria-hidden="true">🔒</span>
      <span
        >Los datos personales (NIF, IBAN, email, teléfono y nombres detectables) se eliminan del
        texto <strong class="font-medium text-ink">antes</strong> de enviarlo para el análisis.</span
      >
    </p>
  </div>

  <div id="print-root">
    <div id="print-cabecera" class="mb-6 hidden print:block"></div>
    <div id="resultado" class="mt-6 space-y-4"></div>
    <p id="print-aviso" class="mt-6 hidden text-xs leading-relaxed text-ink-mid print:block">
      Informe generado automáticamente por arras-ai. Herramienta experimental: puede contener
      errores y <strong>no sustituye</strong> el asesoramiento de un abogado o notario. Verifica
      siempre el resultado con el contrato original.
    </p>
  </div>

  <div id="acciones" class="no-print mt-4 hidden flex-wrap items-center gap-3">
    <button
      id="descargar"
      class="inline-flex items-center gap-2 rounded-pill border border-ink/20 px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:bg-surface"
    >
      <span aria-hidden="true">↓</span> Descargar informe (PDF)
    </button>
    <button
      id="limpiar"
      class="rounded-pill px-4 py-2.5 text-sm font-medium text-ink-mid transition-colors hover:text-ink"
    >
      Limpiar
    </button>
  </div>
</section>

<script>
  import { aVista, type Informe } from "../lib/vista";
  import { EJEMPLOS } from "../examples";

  const $ = (id: string) => document.getElementById(id)!;
  const texto = $("texto") as HTMLTextAreaElement;
  const pdf = $("pdf") as HTMLInputElement;
  let modo: "texto" | "pdf" = "texto";

  // Persist the last analysis locally so it survives refresh / navigation.
  const STORE_KEY = "arras:ultimo-informe";
  function mostrarAcciones(on: boolean) {
    $("acciones").classList.toggle("hidden", !on);
    $("acciones").classList.toggle("flex", on);
  }
  function limpiarResultado() {
    $("resultado").innerHTML = "";
    $("print-cabecera").innerHTML = "";
    mostrarAcciones(false);
  }

  const TAB_ON = "tab rounded-pill px-4 py-1.5 text-[15px] font-medium bg-ink text-surface";
  const TAB_OFF = "tab rounded-pill px-4 py-1.5 text-[15px] font-medium text-ink-mid";

  document.querySelectorAll<HTMLButtonElement>(".tab").forEach((b) =>
    b.addEventListener("click", () => {
      modo = b.dataset.modo as "texto" | "pdf";
      $("panel-texto").classList.toggle("hidden", modo !== "texto");
      $("panel-pdf").classList.toggle("hidden", modo !== "pdf");
      document.querySelectorAll<HTMLButtonElement>(".tab").forEach((t) => {
        t.className = t.dataset.modo === modo ? TAB_ON : TAB_OFF;
      });
    }),
  );

  document.querySelectorAll<HTMLButtonElement>(".ejemplo").forEach((b) =>
    b.addEventListener("click", () => {
      const e = EJEMPLOS.find((x) => x.id === b.dataset.id);
      if (e) texto.value = e.texto;
    }),
  );

  pdf.addEventListener("change", () => {
    const f = pdf.files?.[0];
    $("pdf-nombre").textContent = f ? f.name : "Máximo 5 MB · 15 páginas";
  });

  function mostrarError(msg: string) {
    const el = $("error");
    el.textContent = msg;
    el.classList.remove("hidden");
  }

  function cargando(on: boolean) {
    ($("analizar") as HTMLButtonElement).disabled = on;
    $("spinner").classList.toggle("hidden", !on);
    $("analizar-label").textContent = on ? "Analizando…" : "Analizar contrato";
  }

  async function fileToBase64(f: File): Promise<string> {
    const buf = new Uint8Array(await f.arrayBuffer());
    let bin = "";
    for (const b of buf) bin += String.fromCharCode(b);
    return btoa(bin);
  }

  async function analizar() {
    $("error").classList.add("hidden");
    limpiarResultado();
    let body: Record<string, string>;
    if (modo === "texto") {
      if (!texto.value.trim()) return mostrarError("Pega el texto del contrato.");
      body = { texto: texto.value };
    } else {
      const f = pdf.files?.[0];
      if (!f) return mostrarError("Selecciona un PDF.");
      if (f.size > 5 * 1024 * 1024) return mostrarError("El PDF supera 5 MB.");
      body = { pdf_base64: await fileToBase64(f) };
    }
    cargando(true);
    try {
      const res = await fetch("/api/analyze", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      if (!res.ok) return mostrarError(data.error ?? "Error inesperado.");
      render(aVista(data as Informe));
      try {
        localStorage.setItem(STORE_KEY, JSON.stringify(data));
      } catch {
        /* storage full or unavailable — non-fatal */
      }
    } catch {
      mostrarError("No se pudo conectar con el servicio.");
    } finally {
      cargando(false);
    }
  }

  function esc(s: string): string {
    return s.replace(/[&<>]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" })[c]!);
  }

  function render(v: ReturnType<typeof aVista>) {
    const datos = v.datos
      .map(
        (d) =>
          `<div class="flex items-baseline justify-between gap-4 border-b border-ink-muted/25 py-2 last:border-0">
            <span class="text-sm text-ink-mid">${esc(d.label)}</span>
            <span class="text-right text-sm font-medium text-ink">${esc(d.valor)}</span>
          </div>`,
      )
      .join("");

    const riesgos = v.riesgos.length
      ? v.riesgos
          .map(
            (r) => `
        <div class="rounded-lg border border-ink-muted/40 bg-surface p-4">
          <div class="flex items-center gap-2">
            <span class="rounded-pill ${r.sevBadge} px-2.5 py-0.5 text-xs font-medium capitalize">${esc(r.severidad)}</span>
            <span class="text-sm font-medium text-ink">${esc(r.categoria)}</span>
          </div>
          <p class="mt-2 text-sm leading-relaxed text-ink-mid">${esc(r.descripcion)}</p>
          <p class="mt-2 text-sm leading-relaxed text-ink"><span class="font-medium">Recomendación:</span> ${esc(r.recomendacion)}</p>
          ${
            r.citas.length
              ? `<p class="mt-2 text-xs text-ink-muted">Cf. ${r.citas.map(esc).join(" · ")}</p>`
              : ""
          }
        </div>`,
          )
          .join("")
      : `<div class="rounded-lg border border-ink-muted/40 bg-surface p-4 text-sm text-ink-mid">Sin riesgos detectados.</div>`;

    $("resultado").innerHTML = `
      <div class="rounded-xl border border-ink-muted/40 bg-surface p-5 shadow-subtle sm:p-6">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <p class="text-sm text-ink-mid">Tipo de arras</p>
            <p class="font-serif text-2xl capitalize tracking-tight text-ink">${esc(v.tipo)}</p>
          </div>
          <span class="rounded-pill ${v.nivelBadge} px-3 py-1 text-sm font-medium">Riesgo ${esc(v.nivel.toLowerCase())}</span>
        </div>
        <div class="mt-3 flex items-center gap-2 text-xs text-ink-mid">
          <span class="inline-block h-1.5 w-24 overflow-hidden rounded-pill bg-ink-muted/30">
            <span class="block h-full rounded-pill bg-ink" style="width:${esc(v.confianzaPct)}"></span>
          </span>
          Confianza ${esc(v.confianzaPct)}
        </div>
        <p class="mt-3 text-sm leading-relaxed text-ink-mid">${esc(v.justificacion)}</p>
      </div>

      <div class="rounded-xl border border-ink-muted/40 bg-surface p-5 sm:p-6">
        <p class="mb-2 text-sm font-medium text-ink">Datos del contrato</p>
        ${datos}
      </div>

      <div>
        <p class="mb-2 text-sm font-medium text-ink">Riesgos detectados</p>
        <div class="space-y-3">${riesgos}</div>
      </div>`;

    const fecha = new Date().toLocaleDateString("es-ES", {
      day: "numeric",
      month: "long",
      year: "numeric",
    });
    $("print-cabecera").innerHTML = `
      <div class="flex items-baseline justify-between border-b border-ink-muted/40 pb-2">
        <span class="font-serif text-lg">arras-ai · informe</span>
        <span class="text-sm text-ink-mid">${esc(fecha)}</span>
      </div>`;
    mostrarAcciones(true);
  }

  $("analizar").addEventListener("click", analizar);
  $("descargar").addEventListener("click", () => window.print());
  $("limpiar").addEventListener("click", () => {
    try {
      localStorage.removeItem(STORE_KEY);
    } catch {
      /* ignore */
    }
    limpiarResultado();
  });

  // Restore the last analysis on load so it survives refresh / navigation.
  try {
    const saved = localStorage.getItem(STORE_KEY);
    if (saved) render(aVista(JSON.parse(saved) as Informe));
  } catch {
    localStorage.removeItem(STORE_KEY);
  }
</script>
